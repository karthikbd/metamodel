# Meta Model Engine — Environment Variables
# Copy this file to .env and fill in your values

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=metaengine123

# OpenAI (used by Hydration Agent 4 — LLM Summariser)
OPENAI_API_KEY=sk-...

# Path the AST extractor will scan when running locally (not in Docker)
REPO_SCAN_ROOT=./sample_repo

# Backend API port (local dev)
BACKEND_PORT=8000

# Frontend API base URL
VITE_API_BASE=http://localhost:8000
